// author: Crypt_Shade (@noobhardik699)
def module Breach-Swap
//Jat9119
def desc "Custom Scripted Module"

on pre_tick {
    if input_active attack {
        if target_entity :player,:armor_stand {
            if falling {
                if holding #sword,#axe {
                    switch #mace
                    wait 0.06 {
                        switch back
                    input attack
                    }
                }
            }
        }
    }
}