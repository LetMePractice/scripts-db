// author: Practice (@letmepractice)
module hitbox-mace 
def desc "Hitbox for mace (auto disable/enable)"

on tick 5 if playing {
    if holding :mace {
        if falling {
            if entity_in_range :player 3.2 {
                damage nearest_entity :player
                module disable hitbox-mace
            }
        }
    }
    
    if_not entity_in_range :player 3.2 {
        if module_disabled hitbox-mace {
            module enable hitbox-mace
        }
    }
}