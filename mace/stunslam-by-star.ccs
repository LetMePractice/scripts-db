// author: T For Tighnari (@silicon06520)
def module stunslam-by-star
def desc "Press Z to stunslam"
on key_press Z {
        if target_entity :player{
        as target_entity {
        if blocking {
        switch #axe
        input left
        wait_random 0.05 0.08
        switch #mace[density]
        wait_random 0.05 0.08
        input left
        switch #axe
   }
  }
 }
}

