// author: 亗 Coldy╰‿╯ (@yronv1)
def module Axe-Shield-Break-Crit
def desc "Perfect axe crit only after breaking a shield."
on shield_break {
  target_entity {
    if entity_is_player {
      if holding #axe {
        if distance_to_player <= 4.27 {
          if falling {
            if attack_progress >= 0.88 {
              input left
              wait 0.05
            }
          }
        }
      }
    }
  }
}