// author: fre4k (@fre4k0137)
module 1spear-dtap
def desc "dtap using spear and mace"

on tick if input_active right {
  if holding #spear {
    if hotbar_has #mace {
      if falling {
        if entity_in range :player 4 {
          if target_entity :player {
            switch #mace
            input left
           }
         }
       }
     }
   }
 }
 
