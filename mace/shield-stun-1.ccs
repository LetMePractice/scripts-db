// author: 1vorie (@ivoryflame67)
module shield-stun
def desc "yeah"

on left_click if playing {
    if holding #sword {
        if target_entity :player {
            as target_entity if blocking {
                if hotbar_has #_axe {
                    switch #_axe
                    wait 0.03 then input left  then input left            switch back
                }
            }
        }
    }
}