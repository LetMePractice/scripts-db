// fatchudsellegerswag

def module chud-slam
def desc "Guarantees shield break into chud slam"

def func click {
    if holding #mace {
        input left
    }
}

def func shield_break {
    if hotbar_has #_axe {
        switch #_axe
        wait_random 0.035 0.055
        while_not 0.005 attack_progress >= 0.92 {}
        input left
        wait 0.03
        switch #mace
        while_not 0.005 attack_progress >= 0.85 {}
        input left
    }
}