// author: .0n6 (@.0n6)
def module shield-breaker
def desc "Breaks shields on blocking players"

on tick 2 {
  if playing {
    if_not blocking {
      if hotbar_has #_axe {
        if target_entity :player,:armor_stand {
          as target_entity if blocking {
            if_not holding #_axe {
              switch #_axe
            }
  
         input attack
                switch back
              }
     
        }
      }
    }
  }
}