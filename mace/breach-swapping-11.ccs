// author: .0n6 (@.0n6)
def module breach-swapping
def desc "Switches to breach mace on left click, then back to sword"

on left_click if playing if_not blocking if target_entity :player {
as target_entity if_not blocking {
      if holding #sword,#axe {
        if hotbar_has <#1482591494161436823>[breach] {
            if targeting_entity {
                    switch <#1482591494161436823>[breach]
                    wait 0.04 switch #sword
                }
            }
        }
    }
}