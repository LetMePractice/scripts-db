// author: Lymmt (@lymt_01)
def module gg-stun-slam
def desc "Hit once with axe, then automatically switch to mace and perform stun slam"

if holding #axe
on left_click if playing {
    if holding #_axe
       input attack
        wait 0.04
        switch #mace
        wait 0.04
       input attack
       wait 0.02
       switch #wind_charge,#sword
    }
}