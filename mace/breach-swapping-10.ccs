// author: Yassouvox (@yassouvox)
def module Breach-Swapping
def desc "yeah"

on tick if playing on left_click{
    if holding #sword {
        if hotbar_has #mace[breach] {
            if target_entity :player {
                switch #mace[breach]
                wait 0.05
                switch #sword
            }
        }
    }
}