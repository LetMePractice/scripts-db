// author: Jello (@jello2210)
def module auto-pearl
def desc "When you press Z, aims at the nearest falling player and throws an ender pearl."

on key_press z {
    if playing {
        if hotbar_has :ender_pearl {
            switch :ender_pearl
            snap_to nearest_entity :player aim legs
            input use
            snap_to nearest_entity :player aim head
            wait 0.05 switch #mace[wind_burst]
          }
     }
}