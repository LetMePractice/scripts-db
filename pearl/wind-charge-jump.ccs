Here it is
def module wind-charge-jump
def desc "Automatically jumps when right-clicking with a wind charge"

on right_click if playing {
    if holding :wind_charge {
        wait 0.0529 input jump
    }
    if off_holding :wind_charge {
        wait 0.0529 input jump
    }
}