Did this one work without an error def module slot7-use
def desc "Press R to switch to slot 7, random wait, right click, then random wait and back to slot 1"

on key_press r {
    if playing {
        if in_game {
            switch 7
            wait random 0.05 0.09
            input use
            wait random 0.05 0.09
            switch 1
        }
    }
}