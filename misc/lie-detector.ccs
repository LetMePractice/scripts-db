module lie-detector
def desc ez lie detuctor

on tick {
    if targeting_entity :human {
        if targeting_enity :lying {
            print "Liar detected!"
            wait random 0.05 0.07 
            input slap
            if targeting_enity :not_lying {
                print "Honest Man detected!"
                wait_random 0.05 0.07
                input hug
            }
        }
    }    
}