def module obi-switcher
def desc "obi switch"

on tick {
   if playing {
      if input_active use {
         if holding #sword {
            if targeting_block {
               if hotbar_has #obsidian {
                  wait 0.02
                  switch #obsidian
                  input right
               }
            }
         }
      }
   }
}