// author: Jello (@jello2210)
def module slot7-use
def desc "Press R to switch to slot 7, wait, right click, then back to slot 1"

on key_press r {
    if playing {
        if in_game {
            switch 7
            wait 0.05
            input use
            wait 0.05
            switch 1
        }
    }
}