// author: Jello (@jello2210)
def module slot7-use
def desc "Press R to switch to slot 7, wait, right click, wait, then back to slot 1"

on key_press r {
    if playing {
        if in_game {
            switch 7
            wait 0.3 {
                input use
                wait 0.3 {
                    switch 1
                }
            }
        }
    }
}