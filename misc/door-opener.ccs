def module door-opener
def desc "opens a door if present"

on right_click {
    !if target_block != #air {
        if holding #sword {
            switch minecraft:door;
            input use;
            switch minecraft:stick;
        }

        if holding #pickaxe {
            switch minecraft:door;
            input use;
            switch minecraft:stick;
        }
    }
}
