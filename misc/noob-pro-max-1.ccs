module Noob-pro-max

on key_press U if playing if hotbar_has #wind {
if hotbar_has #pearl {
snap_to polar -33 ~
switch #pearl
input right 
wait_random 0.07 0.1 {
snap_to polar -22 ~
switch #wind
input right
}
wait_random 0.14 0.20 {
switch #sword
        }
    }
}