// author: Jello (@jello2210)
def module chestplate-equip
def desc "Equip chestplate from hotbar; return to previous slot"

on key_press r {
    if playing {
        if in_game {
            if hotbar_has #chestplate {
                switch #chestplate
                wait 0.03 input use
                wait 0.02 switch back
            }
            if hotbar_has #sword {
                wait 0.02 switch #sword
            }
        }
    }
}