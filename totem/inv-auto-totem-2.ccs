// author: suckyswags (@suckyswags)
def module inv-auto-totem
def desc "Pull totems into slot 4 + offhand when pressing E"

on key_press e if playing {

    input inventory
    wait 0.05

    if inventory_has #totem {

        # move totem → offhand
        gui_swap #totem
        wait 0.05

        # move totem → slot 4
        gui_switch 4
        wait 0.05
        gui_swap #totem

    }

    wait 0.05
    input inventory
} 

