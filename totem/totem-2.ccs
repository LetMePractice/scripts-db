like this?
def module totem
def desc "swaps to 8th slot on totem pop"

on totem_pop wait 0.05 {
    if hotbar_has #totem {
        switch #totem
        wait 0.05 {
            swap
        }
    }

    if inventory_has #totem {
        wait 0.05 {
            input inventory
        }
        wait 0.05 {
            gui_swap #totem with_slot 7
        }
        wait 0.05 {
            input inventory
        }
    }
}