// @matrix on top
def module legit-inv-totem
def desc "Opens inv on totem pop and closes when a new totem appears"

on totem_pop if playing {
   if_not input_active inventory {
      wait_random 0.02 0.05
      input inventory
   }
}

on tick if playing {
   if input_active inventory if off_holding #totem {
      wait_random 0.02 0.05
      input inventory
   }
}