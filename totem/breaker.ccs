module breaker
def desc breaker
on tick if input_active attack if holding #totem if target_block :stone,:deepslate wait 0.03 then switch #pickaxe
on tick if input_active attack if holding #sword if target_block :stone,:deepslate wait 0.03 then switch #pickaxe
on break_block if holding #pickaxe then wait 0.03 then switch back