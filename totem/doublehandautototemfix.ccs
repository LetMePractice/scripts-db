// author: Esorlex (@esorlex)
module DoubleHandAutoTotemFix
def desc "Fixes totem swapping in both hands without delay"

on totem_pop if input_active inventory {
    gui_swap #totem
    gui_quickmove #totem 5
}

on key_press e {
    gui_swap #totem
    gui_quickmove #totem 5
}

