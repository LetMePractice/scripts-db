// author: suckyswags (@suckyswags)
def module inv-auto-totem1
def desc "auto totem1"

on key_press e if playing {
   if inventory_has #totem {
      if_not off_holding #totem {
         if_not input_active inventory {
            input inventory
            wait 0.08
         }
         gui_quickmove #totem 4
         wait 0.5
         if input_active inventory {
            input inventory
         }
      }
   }
}