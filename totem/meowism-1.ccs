def module Meowism
def desc "Meowism"


on totem_pop {
   if playing {
      if hotbar_has :totem_of_undying {
         wait_random 0.02 0.05 {
            switch :totem_of_undying then if holding :totem_of_undying wait 0.05 swap {
            switch back
            }
         }
      }
   }
}