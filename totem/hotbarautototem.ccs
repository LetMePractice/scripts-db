// author: ImproperIssues (@improperissues)
def module hotbarautototem
def desc "Auto-totem but just for your hotbar."

on totem_pop if playing {
    if_not hotbar_has #totem {
        input inventory 
        execute_period 0.05 {
            gui_quickmove #totem 5 
            input inventory 
            switch #totem 
            swap
        }
    }
}