// author: Practice (@letmepractice)
module double-totem
def desc "Auto fill both hands with totems"

on key_press e if playing {
    if inventory_has #totem {
        wait 0.05
        gui_swap #totem
    }

    !if hotbar_has #totem {
        wait 0.06
        gui_quickmove #totem 4
        switch #totem 
    }
}