// author: suckyswags (@suckyswags)
def module inv-tot
def desc "when you open the inv, it automatically puts tot in offhand and to hotbar slot 7"

on key_press e if playing if_not off_holding #totem {
    if inventory_has #totem {
        wait 0.05 if input_active inventory {
            gui_swap #totem 
            wait 0.05 gui_quickmove #totem 7
            wait 0.05 if input_active inventory {
                input inventory
            }
        }
    }
}