// author: b8mboclat (@_ra5e)
def module auto-spear-swap
def desc "Spear Ability Swap by KleckserHD"

on tick if playing {
   if holding #golden_apple {
      if input_active attack {
         if hotbar_has #spear {
            switch #spear
            wait 0.05
            input attack
            wait 0.05
            switch #golden_apple
         }
      }
   }
}
how do I make it so this also works with wind charges?