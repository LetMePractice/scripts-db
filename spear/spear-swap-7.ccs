// author: Not_Tahsin (@not_tahsin7)
def module spear swap
def desc "spear dashes on middle click"

on middle_click
    if playing 
      if_not blocking 
        if hotbar_has #spear {
          switch #spear
            input left
              wait 0.07
                switch  #wind_charge
                  if entity_in_range :player 5 {
                    switch :mace
               }
        }
}