def module bypass-web
def desc "Places a cobweb only when looking at common ground blocks"

on right_click if playing if hotbar_has :cobweb wait 0.05 { 
   if holding #sword,#_axe {
      if targeting_block {
         switch :cobweb
         wait 0.05
         input right
         wait 0.05
         switch #sword
      }
   }
}   


