def module anchor-auto
def desc Anchor place + charge + switch back

on right_click if holding #totem_of_undying if hotbar_has #respawn_anchor,#glowstone
wait 0.04 switch #respawn_anchor
wait 0.05 input right
wait 0.05 switch #glowstone
wait 0.04 input right
wait 0.06 switch #totem_of_undying
wait 0.03 input right