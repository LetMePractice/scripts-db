def module anchor-charge
def desc Anchor Charge

on key_press q !if blocking if off_holding #totem {
  switch #anchor then input right switch #glowstone
  wait 0.05{
  input right
  }
  switch #anchor
  wait 0.05{
  input right
  }
}

