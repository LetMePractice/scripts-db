// author: suckyswags (@suckyswags)
def module anchor_macro
def desc "Simple anchor charge + detonate macro"

# Charge anchor
on right_click {
    if holding anchor if target_block respawn_anchor {
        switch glowstone
        wait 0.03 input use
    }
}

# Detonate anchor
on right_click {
    if holding glowstone if target_block charged_respawn_anchor {
        switch totem
        wait 0.03 input use
    }
}