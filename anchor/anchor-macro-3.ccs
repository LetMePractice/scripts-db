// author: Kaira (@_timel3ss.)
def module Anchor-Macro
def desc Anchor Macro

on place_block {
  if holding #anchor {
    wait 0.03 if hotbar_has #glowstone {
      switch #glowstone
      input right

      wait 0.03 if hotbar_has #totem {
        switch #totem
        input right
      }
    }
  }
}