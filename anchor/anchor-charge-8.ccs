// author: matheus cunha (@dominkroptru123)
def module anchor-charge
def desc Anchor Charge

on tick if holding #anchor,#glowstone !if blocking !if holding :golden_apple,:shield if off_holding #totem {
  if target_block :uncharged_respawn_anchor switch #glowstone then input right 
  if target_block :charged_respawn_anchor switch #anchor then input right
}

on key_press R {
    switch #anchor
    wait 0.05 then input right
}