module double-clicker
def desc "Double clicks only for XP bottles, crystals, and respawn anchors"

on left_release if playing {
   if holding :end_crystal,:respawn_anchor {
      input attack
   }
}

on right_release if playing {
   if holding :experience_bottle,:end_crystal,:respawn_anchor {
      input use
   }
}