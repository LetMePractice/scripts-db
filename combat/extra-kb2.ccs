// author: Jello (@jello2210)
def module extra-kb2
def desc "s-tapper"

on packet_receive entityDamage {
   if playing {
      if targeting_entity {
         if target_entity :player {
            if sprinting {
               if_not blocking {
                  if holding #sword,#axe,#mace {
                     wait 0.02
                     hold_input backward 0.3
                  }
               }
            }
         }
      }
   }
}