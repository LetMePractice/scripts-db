// @SillyKoyuki
def module Legit-Totem-Swap-Nethpot
def desc "Not This Time..."

on tick 5 {
   if health <= 7 {
      if hotbar_has #totem {
         if_not off_holding #totem {
            if_not input_active right {
               switch #totem 
               wait 0.15
               input key f
               wait 0.05
               switch back
            }
         }
      }
   }
}