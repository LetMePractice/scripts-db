def module coherent-trigger-bot
def desc "Coherent Client's Trigger Bot"

on pre_tick if input_active left_control if playing if target_entity :player,:armor_stand !if blocking {
   if attack_progress >=0.9 {
      as target_entity if blocking {
         switch #axe
         wait 0.05 switch back
      }
      input attack
   }
}