def module coherent-trigger-bot
def desc "Coherent Client's Trigger Bot"

on tick if playing if target_entity :player !if blocking if input_active sprint {
   if attack_progress >=0.9 {
      as target_entity if blocking as client {
         switch #axe then input left
         wait 0.05 switch back
      }
      input attack
   }
}