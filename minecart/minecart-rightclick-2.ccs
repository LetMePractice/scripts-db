// author: NoIwill (@nomore_bs)
def module minecart-rightclick
def desc "minecart stuff"

if holding :tnt_minecart {
  on item_use {
    wait 0.06
    switch #flint_and_steel
    wait 0.05
    snap_to position ^ ^ ^9
  }
}
if holding :flint_and_steel {
    on item_use {
        wait 0.05
         switch #crossbow
        }
    }