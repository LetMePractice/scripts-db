<@1068969484796297216> ```def module CartPVP
def desc 

on tick {
    if playing {
        if targeting_block {
            if target_block :rail {
                if hotbar_has :tnt_minecart {
                switch :tnt_minecart then wait 0.05 input use
                }
            }
        }
        if holding :tnt_minecart {
            wait 0.05 switch :bow 
            wait 0.05 hold_input use 0.3
        }
    }
}