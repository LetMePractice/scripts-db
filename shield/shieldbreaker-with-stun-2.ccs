def module ShieldBreaker-with-Stun
def desc "Shield Breaker with Auto stun"

on left_click if playing {
   if holding #sword {
         as target_entity if blocking {
            switch #_axe
            input attack
            wait 0.05
            input attack
            switch #sword
         }
      }
   }
}

