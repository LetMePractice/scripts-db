// author: Practice (@letmepractice)
module shieldbreaker-with-stun
def desc "Shield Breaker with Auto stun"

on tick 3 if playing {
   if holding #sword {
      if on_ground {
         if target_entity :player {
            as target_entity {
               if blocking {
                  switch #_axe
                  input attack
                  wait 0.06
                  input attack
                  switch #sword
               }
            }
         }
      }
   }
}